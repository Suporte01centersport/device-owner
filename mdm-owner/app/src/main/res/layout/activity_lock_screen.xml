<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FF000000"
    android:padding="32dp"
    android:visibility="visible">

    <TextView
        android:id="@+id/lock_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒"
        android:textSize="80sp"
        android:textColor="#FFFFFFFF"
        android:visibility="visible"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/lock_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Peça para seu líder desbloquear"
        android:textSize="18sp"
        android:textColor="#FFFFFFFF"
        android:gravity="center"
        android:visibility="visible"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/lock_password_input"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:minHeight="56dp"
        android:minWidth="200dp"
        android:inputType="numberPassword"
        android:maxLength="4"
        android:hint="Senha (4 dígitos)"
        android:textColor="#FFFFFFFF"
        android:textColorHint="#FFCCCCCC"
        android:background="@drawable/lock_input_bg"
        android:padding="16dp"
        android:textSize="24sp"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:cursorVisible="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:visibility="visible" />

    <Button
        android:id="@+id/lock_unlock_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:text="Desbloquear"
        android:textSize="16sp"
        android:textColor="#FFFFFFFF"
        android:background="@drawable/btn_lock_unlock"
        android:padding="16dp"
        android:visibility="visible" />

</LinearLayout>
