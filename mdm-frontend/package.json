{
  "name": "mdm-frontend",
  "version": "1.0.0",
  "description": "Painel web para gerenciamento de dispositivos MDM",
  "main": "index.js",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:network": "next dev -p 3000 -H 0.0.0.0",
    "dev:win": "node -r dotenv/config server/websocket.js dotenv_config_path=.env.development & next dev -p 3000",
    "dev:websocket": "node -r dotenv/config server/websocket.js dotenv_config_path=.env.development",
    "dev:all": "concurrently -k -n ws,web -c blue,green \"npm run dev:websocket\" \"next dev -p 3000\"",
    "dev:all:network": "concurrently -k -n ws,web -c blue,green \"npm run dev:websocket\" \"next dev -p 3000 -H 0.0.0.0\"",
    "kill-node": "powershell -Command \"Get-Process node -ErrorAction SilentlyContinue | Stop-Process -Force\"",
    "dev:restart": "npm run kill-node && npm run dev:all",
    "build": "next build",
    "start": "next start -p 3000",
    "start:prod": "cross-env NODE_ENV=production node -r dotenv/config server/websocket.js dotenv_config_path=.env.production & next start -p 3000",
    "websocket:prod": "cross-env NODE_ENV=production node -r dotenv/config server/websocket.js dotenv_config_path=.env.production",
    "lint": "next lint",
    "websocket": "node server/websocket.js",
    "setup-db": "node server/scripts/setup-db-user.js",
    "db:setup-user": "node server/scripts/setup-db-user.js",
    "migrate": "node server/migrate-to-postgresql.js",
    "db:setup": "npm run setup-db && npm run migrate",
    "configure-existing": "node server/scripts/configure-existing-db.js",
    "cleanup-devices": "node server/scripts/cleanup-orphaned-devices.js",
    "cleanup-devices:confirm": "node server/scripts/cleanup-orphaned-devices.js --confirm",
    "remove-duplicates": "node server/scripts/remove-duplicate-devices.js",
    "remove-duplicates:confirm": "node server/scripts/remove-duplicate-devices.js --confirm",
    "fix-null-device-ids": "node server/scripts/fix-null-device-ids.js",
    "fix-null-device-ids:confirm": "node server/scripts/fix-null-device-ids.js --confirm",
    "db:check": "node scripts/db/check-db.js",
    "db:check-all": "node scripts/db/check-all-tables.js",
    "db:check-alert-history": "node scripts/db/check-alert-history-table.js",
    "db:migrate:add-new-fields": "node server/database/migrations/run-add-new-fields.js",
    "db:migrate:group-apps": "node server/database/migrations/run-add-group-available-apps.js",
    "db:migrate:group-restrictions": "node server/database/migrations/run-add-group-restrictions.js",
    "db:migrate:alert-history": "node server/database/migrations/run-add-group-alert-history.js",
    "db:migrate:computers": "node server/database/migrations/run-add-computers-tables.js",
    "db:migrate:computer-location": "node server/database/migrations/run-add-computer-location-fields.js",
    "db:migrate:device-users-extended": "node server/database/migrations/run-add-device-users-extended.js",
    "db:migrate:device-users-role-password": "node server/database/migrations/run-add-device-users-role-password.js"
  },
  "dependencies": {
    "@coreui/icons-react": "^2.3.0",
    "@react-pdf/renderer": "^4.3.1",
    "appwrite": "^12.0.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "concurrently": "^8.2.0",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.0.0",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "^2.15.4",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.0",
    "tailwindcss": "^3.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.5.6",
    "typescript": "^5.0.0"
  }
}
