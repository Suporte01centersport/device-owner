# ==============================================
# TEMPLATE - Copie para .env ou .env.development
# ==============================================

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mdm_owner_dev
DB_USER=mdm_user
DB_PASSWORD=mdm_dev_password
DB_SSL=false

# Alternativa: use postgres (senha da instalação)
# DB_USER=postgres
# DB_PASSWORD=sua_senha_postgres

# WebSocket
WEBSOCKET_PORT=3001
WEBSOCKET_HOST=localhost
# IP do PC na rede WiFi para celular (ex: 192.168.2.83). Se vazio, auto-detecta.
WEBSOCKET_CLIENT_HOST=

# Admin
ADMIN_PASSWORD=admin123

# URL pública do WebSocket — OBRIGATÓRIO para dispositivos em redes/locais diferentes
# Coloque o IP público ou domínio do servidor. Porta 3001 deve estar aberta no firewall/roteador.
# Exemplos:
#   WEBSOCKET_PUBLIC_URL=http://200.100.50.25:3001       (IP público com porta forwarding)
#   WEBSOCKET_PUBLIC_URL=https://mdm.suaempresa.com      (domínio com HTTPS/nginx)
# Se vazio, MDM só funciona na mesma rede WiFi do servidor.
WEBSOCKET_PUBLIC_URL=

# URL base pública (para APK download de qualquer rede — usa WEBSOCKET_PUBLIC_URL se definida)
# MDM_PUBLIC_URL=http://SEU_IP:3001
